@ModuleInfo { minPklVersion = "0.30.0" }
@go.Package { name = "github.com/apple/pkl-readers/\(prometheus.readerName)/internal/msg/promql" }
module pkl.prometheus.promql

import "@go/go.pkl"

import "./prometheus.pkl"

/// Parse a [PromQL](https://prometheus.io/docs/prometheus/latest/querying/basics/) expression.
class Parse extends prometheus.Request {
  fixed kind: String = "parse"

  /// PromQL query to parse.
  query: String

  /// Resulting error message from parsing [query].
  ///
  /// Empty string if no parse error occurrs.
  hidden fixed parseError: String = if (query.isEmpty) "" else read(requestUri.toString()).text

  /// Indicates if [query] is valid PromQL.
  ///
  /// Empty queries are always valid.
  hidden fixed isValid: Boolean = query.isEmpty || parseError.isEmpty

  /// Check if [query] is valid PromQL and throw an error if it is not.
  ///
  /// The [context] provides additional user-supplied context to help identify invalid queries.
  /// If it is not null, it is included in the thrown error's message.
  function check(context: String?): Boolean =
    if (isValid)
      true
    else if (context == null)
      throw("Invalid PromQL query:\n\(query)\n\nError:\n\(parseError)")
    else
      throw("Invalid PromQL query (\(context)):\n\(query)\n\nError:\n\(parseError)")
}

/// A function that may be used as a type constraint to check if a [String] is valid PromQL query.
///
/// Equivalent to the result of [isValidPromQLWithContext] with a `null` context.
///
/// Example:
/// ```
/// query: String(promethus.isValidPromQL)
/// ```
hidden const isValid: (String) -> Boolean = isValidWithContext(null)

/// Returns a function that may be used as a type constraint to check if a [String] is valid PromQL
/// query with the supplied [context] string.
///
/// Example:
/// ```
/// alertName: String
///
/// query: String(promethus.isValidPromQLWithContext(alertName))
/// ```
const function isValidWithContext(context: String?): (String) -> Boolean = (q) ->
  new Parse { query = q }.check(context)
