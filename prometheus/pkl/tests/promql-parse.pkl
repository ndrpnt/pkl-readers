amends "pkl:test"

import "../promql.pkl"

examples {
  ["valid queries"] {
    new promql.Parse { query = "" }.parseError
    new promql.Parse { query = "foo" }.parseError
    new promql.Parse {
      query =
        """
        foo:bar:1m{baz="qux"} / on (quux) foo:baz:1m{bar="qux"} offset -30m
        """
    }.parseError
  }
  ["error with no context"] {
    module.catch(() ->
      promql.isValid.apply(
        """
        foo{bar="baz"
        """,
      )
    )
  }
  ["error with context"] {
    module.catch(() ->
      promql
        .isValidWithContext("my cool context")
        .apply(
          """
          foo{bar="baz"
          """,
        )
    )
  }
}
